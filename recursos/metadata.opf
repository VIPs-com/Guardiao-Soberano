    <!-- Título -->
    <dc:title>Guardião Soberano — Da Semente ao Ecossistema Completo</dc:title>
    <meta refines="#title" property="title-type">main</meta>
    <meta refines="#title" property="display-seq">1</meta>

    <!-- Subtítulo -->
    <dc:title id="subtitle">Manual Prático de Auto-Custódia Bitcoin com Privacidade</dc:title>
    <meta refines="#subtitle" property="title-type">subtitle</meta>
    <meta refines="#subtitle" property="display-seq">2</meta>

