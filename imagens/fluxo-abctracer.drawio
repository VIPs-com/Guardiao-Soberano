<mxfile host="app.diagrams.net" type="device">
  <diagram name="ABCTracer - Defesa por Fragmentação e Timing">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="100" value="ABCTracer — Correlação Cross-Chain: Como se Defender" style="text;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- CENTER DIVIDER -->
        <mxCell id="90" value="" style="endArrow=none;startArrow=none;strokeColor=#888888;strokeWidth=3;dashed=1;" edge="1" parent="1">
          <mxGeometry x="550" y="70" width="0" height="620" as="geometry"><Array as="points"><mxPoint x="550" y="70"/><mxPoint x="550" y="690"/></Array></mxGeometry>
        </mxCell>

        <!-- LEFT SIDE: SEM DEFESA (red) -->
        <mxCell id="10" value="❌ SEM DEFESA" style="text;fontSize=20;fontStyle=1;fontColor=#cc0000;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="380" height="40" as="geometry"/>
        </mxCell>

        <!-- Timeline: immediate swap -->
        <mxCell id="11" value="14:00 — BTC misturado&#xa;1.0 BTC → eigenwallet" style="rounded=1;fillColor=#ffcccc;strokeColor=#cc4444;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="380" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="↓ 25 minutos depois" style="text;fontSize=13;fontStyle=2;fontColor=#cc4444;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="210" width="380" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="14:25 — ~0.98 XMR aparece&#xa;na carteira Monero" style="rounded=1;fillColor=#ffcccc;strokeColor=#cc4444;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="250" width="380" height="70" as="geometry"/>
        </mxCell>

        <!-- Alert box -->
        <mxCell id="14" value="⚠️ ABCTracer detecta:&#xa;Intervalo: 25 minutos&#xa;Confiança: 91.75%&#xa;CORRELACIONADO" style="rounded=1;fillColor=#cc0000;strokeColor=#990000;fontSize=15;fontColor=#FFFFFF;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="340" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="15" value="O analista sabe que&#xa;1.0 BTC → ~0.98 XMR → VOCÊ" style="text;fontSize=13;fontColor=#cc0000;align=center;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="380" height="50" as="geometry"/>
        </mxCell>

        <!-- RIGHT SIDE: COM DEFESA (green) -->
        <mxCell id="20" value="✅ COM DEFESA" style="text;fontSize=20;fontStyle=1;fontColor=#007700;align=center;" vertex="1" parent="1">
          <mxGeometry x="580" y="70" width="380" height="40" as="geometry"/>
        </mxCell>

        <!-- Fragmented swaps over multiple days -->
        <mxCell id="21" value="Dia 1 — 0.4 BTC → eigenwallet" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="580" y="130" width="380" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="Dia 3 — 0.3 BTC → eigenwallet" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="580" y="200" width="380" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="Dia 5 — 0.5 BTC → eigenwallet" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="580" y="270" width="380" height="55" as="geometry"/>
        </mxCell>

        <!-- Timeline arrows -->
        <mxCell id="24" value="48h depois" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;dashed=1;" edge="1" parent="1" source="21" target="22"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="25" value="48h depois" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;dashed=1;" edge="1" parent="1" source="22" target="23"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Success box -->
        <mxCell id="26" value="✅ ABCTracer falha:&#xa;3 transações separadas&#xa;3 horários diferentes&#xa;3 valores diferentes&#xa;NÃO CORRELACIONADO" style="rounded=1;fillColor=#007700;strokeColor=#005500;fontSize=14;fontColor=#FFFFFF;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="600" y="360" width="340" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="27" value="Analista NÃO consegue linkar&#xa;os 3 fragmentos XMR a VOCÊ" style="text;fontSize=13;fontColor=#007700;align=center;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="580" y="510" width="380" height="50" as="geometry"/>
        </mxCell>

        <!-- Rules summary at bottom -->
        <mxCell id="30" value="📋 Regras de Defesa: (1) Fragmentar em 3+ partes  (2) Mínimo 24h entre swaps  (3) Valores irregulares" style="fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="900" height="50" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
